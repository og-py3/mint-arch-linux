# Mint OS — I/O Scheduler Optimization

# NVMe SSDs → none (they have their own internal queuing)
ACTION=="add|change", KERNEL=="nvme[0-9]*", ATTR{queue/scheduler}="none"

# SATA SSDs → mq-deadline
ACTION=="add|change", KERNEL=="sd[a-z]|xvd[a-z]|vd[a-z]", \
  ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="mq-deadline"

# HDDs → bfq (best for spinning disks)
ACTION=="add|change", KERNEL=="sd[a-z]|xvd[a-z]|vd[a-z]", \
  ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="bfq"

# Read-ahead: 2MB for SSDs, 8MB for HDDs
ACTION=="add|change", KERNEL=="sd[a-z]|nvme[0-9]*", \
  ATTR{queue/rotational}=="0", ATTR{bdi/read_ahead_kb}="2048"
ACTION=="add|change", KERNEL=="sd[a-z]", \
  ATTR{queue/rotational}=="1", ATTR{bdi/read_ahead_kb}="8192"

# USB power management
ACTION=="add", SUBSYSTEM=="usb", TEST=="power/control", \
  ATTR{power/control}="auto"
