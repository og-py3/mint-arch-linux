#!/usr/bin/env bash
# =============================================================================
# Mint Arch Linux - Security Tools Manager
# Powered by BlackArch Linux Repository (2800+ tools)
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
MINT='\033[38;2;46;203;113m'
NC='\033[0m'

banner() {
    echo -e "${CYAN}"
    echo "  ███╗   ███╗██╗███╗   ██╗████████╗     ████████╗ ██████╗  ██████╗ ██╗     ███████╗"
    echo "  ████╗ ████║██║████╗  ██║╚══██╔══╝        ██╔══╝██╔═══██╗██╔═══██╗██║     ██╔════╝"
    echo "  ██╔████╔██║██║██╔██╗ ██║   ██║           ██║   ██║   ██║██║   ██║██║     ███████╗"
    echo "  ██║╚██╔╝██║██║██║╚██╗██║   ██║           ██║   ██║   ██║██║   ██║██║     ╚════██║"
    echo "  ██║ ╚═╝ ██║██║██║ ╚████║   ██║           ██║   ╚██████╔╝╚██████╔╝███████╗███████║"
    echo "  ╚═╝     ╚═╝╚═╝╚═╝  ╚═══╝   ╚═╝           ╚═╝    ╚═════╝  ╚═════╝ ╚══════╝╚══════╝"
    echo -e "${NC}"
    echo -e "  ${BOLD}${MINT}Mint Arch Linux — Security Tools Manager${NC}"
    echo -e "  ${CYAN}Powered by BlackArch Linux Repository (2800+ tools)${NC}"
    echo "  ────────────────────────────────────────────────────────"
    echo ""
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}[!] Please run as root: sudo mint-tools-setup${NC}"
        exit 1
    fi
}

ensure_blackarch() {
    if ! grep -q '\[blackarch\]' /etc/pacman.conf 2>/dev/null; then
        echo -e "${YELLOW}[!] BlackArch repo not found. Adding it now...${NC}"
        curl -O https://blackarch.org/strap.sh
        chmod +x strap.sh
        bash strap.sh
        rm -f strap.sh
        pacman -Sy --noconfirm
        echo -e "${GREEN}[✓] BlackArch repo added (2800+ tools available)${NC}"
    else
        echo -e "${GREEN}[✓] BlackArch repo ready${NC}"
    fi
}

install_group() {
    local label="$1"
    local group="$2"
    echo -e "${GREEN}[+] Installing: ${BOLD}$label${NC} (${CYAN}blackarch-${group}${NC})"
    pacman -S --needed --noconfirm "blackarch-${group}" 2>/dev/null || {
        echo -e "${YELLOW}[!] Group install failed, trying individual packages...${NC}"
        pacman -Sg "blackarch-${group}" 2>/dev/null | awk '{print $2}' | \
            xargs -r pacman -S --needed --noconfirm 2>/dev/null || true
    }
    echo -e "${GREEN}[✓] $label installed${NC}"
}

install_pkgs() {
    local label="$1"; shift
    local pkgs=("$@")
    echo -e "${GREEN}[+] Installing: ${BOLD}$label${NC}"
    pacman -S --needed --noconfirm "${pkgs[@]}" 2>/dev/null || true
}

# ─── BlackArch Groups (2800+ tools total) ─────────────────────────────────────

cat_exploitation()       { install_group "Exploitation"                exploitation; }
cat_fuzzer()             { install_group "Fuzzers"                      fuzzer; }
cat_forensic()           { install_group "Forensics & Recovery"         forensic; }
cat_recon()              { install_group "Reconnaissance"               recon; }
cat_scanner()            { install_group "Scanners & Port Scanners"     scanner; }
cat_webapp()             { install_group "Web Application Testing"      webapp; }
cat_networking()         { install_group "Networking"                   networking; }
cat_crypto()             { install_group "Cryptography & Encoding"      crypto; }
cat_misc()               { install_group "Miscellaneous"                misc; }
cat_reversing()          { install_group "Reverse Engineering"          reversing; }
cat_mobile()             { install_group "Mobile Security"              mobile; }
cat_cracker()            { install_group "Password Crackers"            cracker; }
cat_sniffer()            { install_group "Sniffers & Traffic Analysis"  sniffer; }
cat_wireless()           { install_group "Wireless & WiFi"              wireless; }
cat_social()             { install_group "Social Engineering"           social; }
cat_voip()               { install_group "VoIP Security"                voip; }
cat_windows()            { install_group "Windows / AD Attacks"         windows; }
cat_anti_forensic()      { install_group "Anti-Forensics"               anti-forensic; }
cat_backdoor()           { install_group "Backdoors & Trojans"          backdoor; }
cat_code_audit()         { install_group "Code Audit & SAST"            code-audit; }
cat_config()             { install_group "Configuration Auditing"       config; }
cat_decompiler()         { install_group "Decompilers"                  decompiler; }
cat_defensive()          { install_group "Defensive & Blue Team"        defensive; }
cat_disassembler()       { install_group "Disassemblers"                disassembler; }
cat_dos()                { install_group "DoS & Stress Testing"         dos; }
cat_drone()              { install_group "Drone / RF Hacking"           drone; }
cat_exploitation_client(){ install_group "Client-Side Exploitation"     exploitation-client; }
cat_fingerprint()        { install_group "Fingerprinting"               fingerprint; }
cat_firmware()           { install_group "Firmware Analysis"            firmware; }
cat_hardware()           { install_group "Hardware Hacking"             hardware; }
cat_honeypot()           { install_group "Honeypots"                    honeypot; }
cat_ids()                { install_group "IDS / IPS"                    ids; }
cat_keylogger()          { install_group "Keyloggers"                   keylogger; }
cat_malware()            { install_group "Malware Analysis"             malware; }
cat_networking2()        { install_group "Network Traffic Analysis"     networking; }
cat_nfc()                { install_group "NFC & RFID"                   nfc; }
cat_osint()              { install_group "OSINT"                        osint; }
cat_packer()             { install_group "Packers & Obfuscators"        packer; }
cat_proxy()              { install_group "Proxies & Tunnels"            proxy; }
cat_radio()              { install_group "Radio / SDR"                  radio; }
cat_spoof()              { install_group "Spoofing"                     spoof; }
cat_stego()              { install_group "Steganography"                stego; }
cat_threat_modeling()    { install_group "Threat Modeling"              threat-modeling; }
cat_tunnel()             { install_group "Tunneling"                    tunnel; }
cat_unpacker()           { install_group "Unpackers"                    unpacker; }
cat_vehicle()            { install_group "Vehicle / CAN Bus"            vehicle; }
cat_windows_priv()       { install_group "Windows Privilege Escalation" windows; }

install_everything() {
    echo -e "${YELLOW}[!] Installing the FULL BlackArch suite (2800+ tools).${NC}"
    echo -e "${YELLOW}    This will download several GB and take a long time.${NC}"
    echo ""
    read -r -p "Are you absolutely sure? (yes/N): " confirm
    [[ "$confirm" == "yes" ]] || { echo "Aborted."; return; }
    pacman -S --needed --noconfirm blackarch
    echo -e "${GREEN}[✓] All 2800+ BlackArch tools installed!${NC}"
}

install_top100() {
    echo -e "${YELLOW}[!] Installing the most popular 100 security tools...${NC}"
    install_pkgs "Top 100 Tools" \
        nmap masscan netdiscover arp-scan whois dnsutils traceroute mtr \
        sqlmap nikto gobuster ffuf wfuzz dirb burpsuite zaproxy \
        hashcat john hydra medusa crunch cewl \
        aircrack-ng kismet wireshark-qt wireshark-cli bettercap mdk4 reaver hcxtools hcxdumptool \
        metasploit exploitdb searchsploit pwntools \
        bloodhound crackmapexec evil-winrm impacket \
        autopsy sleuthkit binwalk foremost testdisk volatility3 exiftool \
        radare2 ghidra cutter gdb pwndbg ltrace strace \
        tcpdump dsniff ettercap responder mitmproxy sslstrip \
        ncat socat proxychains-ng tor openvpn wireguard-tools sslscan \
        steghide stegseek openssl age gnupg \
        maltego recon-ng theharvester amass subfinder nuclei \
        set gophish \
        trivy dive grype syft kubectl \
        apktool jadx frida adb androguard \
        snort suricata zeek rkhunter lynis clamav auditd \
        ffuf radamsa \
        sqlmap redis shodan
    echo -e "${GREEN}[✓] Top 100 tools installed!${NC}"
}

# ─── Menu ─────────────────────────────────────────────────────────────────────

show_menu() {
    echo -e "${BOLD}Select a tool category to install:${NC}"
    echo ""
    echo -e "  ${CYAN}── Quick Install ──────────────────────────────────────${NC}"
    echo "   T)  Top 100 Most Popular Tools     (fast, ~2GB)"
    echo "   A)  ALL BlackArch Tools             (2800+ tools, ~20GB)"
    echo ""
    echo -e "  ${CYAN}── BlackArch Groups ───────────────────────────────────${NC}"
    echo "   1)  Exploitation                   40)  Anti-Forensics"
    echo "   2)  Fuzzers                        41)  Backdoors & Trojans"
    echo "   3)  Forensics & Recovery           42)  Code Audit / SAST"
    echo "   4)  Reconnaissance                 43)  Configuration Auditing"
    echo "   5)  Scanners & Port Scanners       44)  Decompilers"
    echo "   6)  Web Application Testing        45)  Defensive / Blue Team"
    echo "   7)  Networking                     46)  Disassemblers"
    echo "   8)  Cryptography & Encoding        47)  DoS & Stress Testing"
    echo "   9)  Miscellaneous                  48)  Drone / RF Hacking"
    echo "  10)  Reverse Engineering            49)  Client-Side Exploitation"
    echo "  11)  Mobile Security                50)  Fingerprinting"
    echo "  12)  Password Crackers              51)  Firmware Analysis"
    echo "  13)  Sniffers & Traffic Analysis    52)  Hardware Hacking"
    echo "  14)  Wireless & WiFi                53)  Honeypots"
    echo "  15)  Social Engineering             54)  IDS / IPS"
    echo "  16)  VoIP Security                  55)  Keyloggers"
    echo "  17)  Windows / AD Attacks           56)  Malware Analysis"
    echo "  18)  OSINT                          57)  NFC & RFID"
    echo "  19)  Proxy & Tunneling              58)  Packers & Obfuscators"
    echo "  20)  Steganography                  59)  Radio / SDR"
    echo "  21)  Spoofing                       60)  Vehicle / CAN Bus"
    echo "  22)  Threat Modeling                61)  Unpackers"
    echo ""
    echo -e "   ${BOLD}L)  List all tools in a group${NC}"
    echo -e "   ${BOLD}S)  Search for a specific tool${NC}"
    echo -e "   ${BOLD}Q)  Quit${NC}"
    echo ""
}

list_group_tools() {
    read -r -p "Enter BlackArch group name (e.g. webapp, recon, cracker): " grp
    echo ""
    echo -e "${CYAN}Tools in blackarch-${grp}:${NC}"
    pacman -Sg "blackarch-${grp}" 2>/dev/null | awk '{print "  - "$2}' || \
        echo -e "${RED}Group not found. Run: pacman -Sg | grep blackarch${NC}"
}

search_tool() {
    read -r -p "Search for tool: " term
    echo ""
    echo -e "${CYAN}Results for '${term}':${NC}"
    pacman -Ss "blackarch" 2>/dev/null | grep -i "$term" | head -30 || true
    pacman -Ss "$term" 2>/dev/null | grep -i "$term" | head -20 || true
}

main() {
    banner
    check_root
    ensure_blackarch

    while true; do
        show_menu
        read -r -p "Choice: " choice
        echo ""
        case "$choice" in
            [Tt]) install_top100 ;;
            [Aa]) install_everything ;;
            1)  cat_exploitation ;;
            2)  cat_fuzzer ;;
            3)  cat_forensic ;;
            4)  cat_recon ;;
            5)  cat_scanner ;;
            6)  cat_webapp ;;
            7)  cat_networking ;;
            8)  cat_crypto ;;
            9)  cat_misc ;;
            10) cat_reversing ;;
            11) cat_mobile ;;
            12) cat_cracker ;;
            13) cat_sniffer ;;
            14) cat_wireless ;;
            15) cat_social ;;
            16) cat_voip ;;
            17) cat_windows ;;
            18) cat_osint ;;
            19) cat_proxy ;;
            20) cat_stego ;;
            21) cat_spoof ;;
            22) cat_threat_modeling ;;
            40) cat_anti_forensic ;;
            41) cat_backdoor ;;
            42) cat_code_audit ;;
            43) cat_config ;;
            44) cat_decompiler ;;
            45) cat_defensive ;;
            46) cat_disassembler ;;
            47) cat_dos ;;
            48) cat_drone ;;
            49) cat_exploitation_client ;;
            50) cat_fingerprint ;;
            51) cat_firmware ;;
            52) cat_hardware ;;
            53) cat_honeypot ;;
            54) cat_ids ;;
            55) cat_keylogger ;;
            56) cat_malware ;;
            57) cat_nfc ;;
            58) cat_packer ;;
            59) cat_radio ;;
            60) cat_vehicle ;;
            61) cat_unpacker ;;
            [Ll]) list_group_tools ;;
            [Ss]) search_tool ;;
            [Qq]) echo -e "${GREEN}Goodbye!${NC}"; exit 0 ;;
            *) echo -e "${RED}[!] Invalid choice.${NC}" ;;
        esac
        echo ""
    done
}

main "$@"
