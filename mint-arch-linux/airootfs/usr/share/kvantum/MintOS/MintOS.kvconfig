[%General]
author=Mint Arch Linux
comment=Mint Arch Linux dark glassmorphism theme with mint-green accents

[GeneralColors]
window.color=#111611
base.color=#161d16
alt.base.color=#111611
button.color=#1a241a
light.color=#2a3a2a
mid.light.color=#1e2e1e
mid.color=#1a2a1a
dark.color=#0d150d
shadow.color=#050d05
highlight.color=#2ecb71
inactive.highlight.color=#1a7a44
highlight.text.color=#ffffff
window.text.color=#d0dbd0
base.text.color=#c8d8c8
button.text.color=#d0dbd0
disabled.text.color=#4a6a4a
tooltip.base.color=#1a2a1a
tooltip.text.color=#c8d8c8
link.color=#2ecb71
active.link.color=#3ddc80

[Hacks]
transparent.dolphin.view=false
blur.konsole=true
transparent.ktitle.label=true
etch.disabled.widgets=false

[PanelButtonCommand]
frame=true
frame.element=button
frame.top=4
frame.bottom=4
frame.left=6
frame.right=6
interior=true
interior.element=button
indicator.size=0
text.normal.color=#d0dbd0
text.focus.color=#ffffff
text.press.color=#ffffff
text.toggle.color=#2ecb71
