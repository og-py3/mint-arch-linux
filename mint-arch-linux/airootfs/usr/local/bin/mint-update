#!/usr/bin/env bash
# =============================================================================
# Mint OS - Safe System Update Script
# Takes a Btrfs/Snapper snapshot before every update for easy rollback
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${GREEN}[+]${NC} $*"; }
warn()    { echo -e "${YELLOW}[!]${NC} $*"; }
error()   { echo -e "${RED}[✗]${NC} $*"; exit 1; }
section() { echo -e "\n${BOLD}${CYAN}── $* ──${NC}\n"; }

check_root() {
    [[ "$EUID" -eq 0 ]] || error "Run as root: sudo mint-update"
}

banner() {
    echo -e "${CYAN}${BOLD}"
    echo "  Mint OS Safe Update Manager"
    echo -e "${NC}"
}

snapshot_exists() {
    command -v snapper &>/dev/null && snapper -c root list &>/dev/null 2>&1
}

pre_update_snapshot() {
    if snapshot_exists; then
        section "Creating Pre-Update Snapshot"
        local desc="mint-update pre-snapshot $(date '+%Y-%m-%d %H:%M')"
        snapper -c root create --description "$desc" --cleanup-algorithm number
        info "Snapshot created: $desc"
    else
        warn "Snapper not configured — skipping snapshot (rollback unavailable)"
    fi
}

update_mirrors() {
    section "Refreshing Mirrors"
    if command -v reflector &>/dev/null; then
        info "Finding fastest mirrors..."
        reflector --latest 20 --sort rate --save /etc/pacman.d/mirrorlist
        info "Mirrorlist updated."
    fi
}

update_system() {
    section "Updating System Packages"
    info "Running pacman -Syu..."
    pacman -Syu --noconfirm

    info "Removing orphaned packages..."
    local orphans
    orphans=$(pacman -Qdtq 2>/dev/null || true)
    if [[ -n "$orphans" ]]; then
        warn "Found orphaned packages:"
        echo "$orphans"
        read -r -p "Remove them? [y/N]: " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] && pacman -Rns $orphans --noconfirm
    else
        info "No orphaned packages found."
    fi

    info "Clearing package cache (keeping last 2 versions)..."
    paccache -rk2 2>/dev/null || true
}

update_aur() {
    section "Updating AUR Packages"
    if command -v paru &>/dev/null; then
        local real_user="${SUDO_USER:-}"
        if [[ -n "$real_user" ]]; then
            info "Updating AUR packages for $real_user..."
            sudo -u "$real_user" paru -Syu --aur --noconfirm 2>/dev/null || \
                warn "Some AUR packages may have failed — check manually with: paru -Syu"
        else
            warn "Could not determine non-root user — skipping AUR update"
        fi
    else
        warn "paru not found — skipping AUR update"
    fi
}

update_flatpak() {
    section "Updating Flatpak Apps"
    if command -v flatpak &>/dev/null; then
        info "Updating flatpak apps..."
        flatpak update --noninteractive || warn "Some flatpak updates failed."
    fi
}

post_update_snapshot() {
    if snapshot_exists; then
        section "Creating Post-Update Snapshot"
        local desc="mint-update post-snapshot $(date '+%Y-%m-%d %H:%M')"
        snapper -c root create --description "$desc" --cleanup-algorithm number
        info "Post-update snapshot created."
    fi
}

check_reboot() {
    section "Reboot Check"
    if [ -f /proc/sys/kernel/kexec_loaded ] && \
       [ "$(uname -r)" != "$(pacman -Q linux 2>/dev/null | awk '{print $2}' | sed 's/-/ /' | awk '{print $1"-"$2"-ARCH"}')" ]; then
        warn "Kernel was updated. A reboot is recommended."
    else
        info "No reboot required."
    fi
}

show_snapshots() {
    if snapshot_exists; then
        section "Recent Snapshots (for rollback)"
        snapper -c root list --columns number,date,description | tail -5
        echo ""
        echo "  To rollback: sudo snapper -c root undochange <N>..<M>"
    fi
}

main() {
    banner
    check_root

    pre_update_snapshot
    update_mirrors
    update_system
    update_aur
    update_flatpak
    post_update_snapshot
    check_reboot
    show_snapshots

    echo ""
    echo -e "${GREEN}${BOLD}Mint OS update complete!${NC}"
    echo ""
}

main "$@"
