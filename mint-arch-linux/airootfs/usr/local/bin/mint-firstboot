#!/usr/bin/env bash
# =============================================================================
# Mint Arch Linux - First Boot Configuration Script
# Runs once on first boot.
# =============================================================================

set -euo pipefail

LOG="/var/log/mint-firstboot.log"
exec > >(tee -a "$LOG") 2>&1

echo "========================================="
echo "  Mint Arch Linux First Boot Setup"
echo "  $(date)"
echo "========================================="

# --- Generate locales ---
echo "[+] Generating locales..."
locale-gen

# --- Set timezone if not set ---
if [ ! -f /etc/localtime ]; then
    echo "[+] Timezone not set — defaulting to UTC."
    ln -sf /usr/share/zoneinfo/UTC /etc/localtime
fi
hwclock --systohc

# --- Enable essential services ---
echo "[+] Enabling services..."
systemctl enable NetworkManager
systemctl enable bluetooth
systemctl enable cups
systemctl enable avahi-daemon
systemctl enable sddm
systemctl enable fstrim.timer
systemctl enable reflector.timer
systemctl enable docker 2>/dev/null || true
systemctl enable paccache.timer
systemctl enable mint-setup-flatpak.service
systemctl enable mint-blackarch.service

# --- Enable auto-update system ---
echo "[+] Enabling Mint auto-update system..."
# Downloads package updates in background (after boot)
systemctl enable mint-autoupdate.timer
# Applies pre-downloaded packages early in next boot (before login screen)
systemctl enable mint-apply-updates.service
echo "    Auto-update enabled: packages will silently update on each boot cycle."

# --- Configure zsh as default shell ---
echo "[+] Setting zsh as default shell..."
chsh -s /usr/bin/zsh root 2>/dev/null || true

# --- Setup mirrors ---
echo "[+] Updating mirrors with reflector..."
reflector --latest 20 --sort rate --save /etc/pacman.d/mirrorlist || true

# --- Update package database ---
echo "[+] Refreshing package database..."
pacman -Sy --noconfirm || true

# --- Setup AUR helper check ---
echo "[+] Checking for AUR helper..."
if ! command -v paru &>/dev/null; then
    echo "    paru not found. Install with: mint-setup-aur"
fi

# --- Copy Mint Arch Linux logo ---
echo "[+] Setting up branding..."
if [ -f /usr/share/mint-arch/logo.png ]; then
    cp /usr/share/mint-arch/logo.png /usr/share/pixmaps/mintarch-logo.png 2>/dev/null || true
fi

# --- Record installed version ---
mkdir -p /var/lib/mint-arch
INSTALLED_VERSION=$(curl -sf --max-time 10 \
    "https://api.github.com/repos/og-py3/mint-arch-linux/releases/latest" \
    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get("tag_name","unknown"))" 2>/dev/null || echo "unknown")
echo "$INSTALLED_VERSION" > /var/lib/mint-arch/distro-version
echo "[+] Installed version recorded: $INSTALLED_VERSION"

# --- Mark first boot done ---
touch /etc/mint-configured

echo ""
echo "========================================="
echo "  Mint Arch Linux First Boot Complete!"
echo "========================================="