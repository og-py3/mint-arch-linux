#!/usr/bin/env bash
# =============================================================================
# Mint Arch Linux — Auto Updater v2
# Runs on boot (after network):
#   1. Checks GitHub for tool/config updates  → applies immediately
#   2. Checks pacman for package updates       → downloads only, applies next boot
#   3. Checks GitHub releases for new version  → notifies user
# =============================================================================

set -euo pipefail

REPO="og-py3/mint-arch-linux"
BRANCH="main"
STATE_DIR="/var/lib/mint-arch"
STATE_FILE="$STATE_DIR/last-commit"
UPDATES_FLAG="$STATE_DIR/updates-ready"
VERSION_FILE="$STATE_DIR/distro-version"
LOG="/var/log/mint-autoupdate.log"

mkdir -p "$STATE_DIR"
exec > >(tee -a "$LOG") 2>&1

log()  { echo "[$(date +%Y-%m-%d\ %H:%M:%S)] $*"; }
info() { log "[INFO] $*"; }
ok()   { log "[OK]   $*"; }
warn() { log "[WARN] $*"; }
err()  { log "[ERR]  $*"; }

# Send KDE notification to the logged-in desktop user
notify_user() {
    local title="$1" body="$2" icon="${3:-system-software-update}"
    local user uid bus
    user=$(who | grep -v root | awk "{print \$1}" | head -1 || true)
    [ -z "$user" ] && return 0
    uid=$(id -u "$user" 2>/dev/null || true)
    [ -z "$uid" ] && return 0
    bus="unix:path=/run/user/${uid}/bus"
    sudo -u "$user" DISPLAY=:0 DBUS_SESSION_BUS_ADDRESS="$bus" \
        notify-send "$title" "$body" --icon="$icon" --app-name="Mint Updater" 2>/dev/null || true
}

info "=================================================="
info "Mint Arch Linux Auto-Updater v2"
info "=================================================="

# Network check
if ! curl -sf --max-time 8 https://archlinux.org > /dev/null 2>&1; then
    warn "No internet — skipping all update checks."
    exit 0
fi

# ==============================================================================
# PHASE 1 — GitHub tool/config updates (apply immediately)
# ==============================================================================
info "-- Phase 1: GitHub tool updates --"

LATEST=$(curl -sf --max-time 15 \
    "https://api.github.com/repos/${REPO}/commits/${BRANCH}" \
    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d["sha"])" 2>/dev/null || echo "")

if [ -n "$LATEST" ]; then
    CURRENT=""
    [ -f "$STATE_FILE" ] && CURRENT=$(cat "$STATE_FILE")

    if [ "$CURRENT" != "$LATEST" ]; then
        info "Tool update available — downloading from GitHub..."
        TMPDIR=$(mktemp -d)
        trap "rm -rf $TMPDIR" EXIT

        curl -sfL --max-time 180 \
            "https://github.com/${REPO}/archive/refs/heads/${BRANCH}.tar.gz" \
            -o "$TMPDIR/update.tar.gz" 2>/dev/null || { warn "Download failed."; }

        if [ -f "$TMPDIR/update.tar.gz" ]; then
            tar -xzf "$TMPDIR/update.tar.gz" -C "$TMPDIR" 2>/dev/null || true
            UPDATE_DIR="$TMPDIR/mint-arch-linux-${BRANCH}"

            # Update mint-* CLI tools
            if [ -d "$UPDATE_DIR/mint-arch-linux/airootfs/usr/local/bin" ]; then
                cp -f "$UPDATE_DIR/mint-arch-linux/airootfs/usr/local/bin"/mint-* \
                      /usr/local/bin/ 2>/dev/null || true
                chmod +x /usr/local/bin/mint-* 2>/dev/null || true
                ok "mint-* tools updated"
            fi

            # Update wallpapers/assets
            if [ -d "$UPDATE_DIR/mint-arch-linux/airootfs/usr/share/mint-arch" ]; then
                mkdir -p /usr/share/mint-arch
                cp -ruf "$UPDATE_DIR/mint-arch-linux/airootfs/usr/share/mint-arch/." \
                        /usr/share/mint-arch/ 2>/dev/null || true
                ok "Assets updated"
            fi

            # Update /etc/motd
            motd_src="$UPDATE_DIR/mint-arch-linux/airootfs/etc/motd"
            [ -f "$motd_src" ] && cp -f "$motd_src" /etc/motd && info "motd updated"

            echo "$LATEST" > "$STATE_FILE"
            ok "Phase 1 complete."
        fi
    else
        info "Tools already up to date."
    fi
else
    warn "Could not reach GitHub API — skipping tool update."
fi

# ==============================================================================
# PHASE 2 — Pacman package updates (download only, apply on next boot)
# ==============================================================================
info "-- Phase 2: Package update pre-download --"

# Refresh package DB
pacman -Sy --noconfirm 2>/dev/null || { warn "pacman -Sy failed — skipping package check."; }

# Count pending updates
PENDING=$(pacman -Qu 2>/dev/null | wc -l || echo 0)

if [ "$PENDING" -gt 0 ]; then
    info "$PENDING package update(s) available — pre-downloading to cache..."

    if pacman -Suw --noconfirm 2>/dev/null; then
        ok "$PENDING package(s) cached successfully."
        echo "$PENDING" > "$UPDATES_FLAG"
        date "+%Y-%m-%d %H:%M:%S" >> "$UPDATES_FLAG"

        notify_user \
            "Mint Arch — Updates Ready" \
            "$PENDING system update(s) downloaded. They will be applied automatically on next boot." \
            "system-software-update"

        info "Flag written: $UPDATES_FLAG"
        info "Updates will be applied on next boot."
    else
        warn "Package pre-download failed — will retry next run."
    fi
else
    info "All packages are up to date."
    rm -f "$UPDATES_FLAG"
fi

# ==============================================================================
# PHASE 3 — GitHub release version check
# ==============================================================================
info "-- Phase 3: Distro release check --"

LATEST_RELEASE=$(curl -sf --max-time 10 \
    "https://api.github.com/repos/${REPO}/releases/latest" \
    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get("tag_name",""))" 2>/dev/null || echo "")

CURRENT_VERSION=""
[ -f "$VERSION_FILE" ] && CURRENT_VERSION=$(cat "$VERSION_FILE")

if [ -n "$LATEST_RELEASE" ]; then
    echo "$LATEST_RELEASE" > "$VERSION_FILE"
    if [ -n "$CURRENT_VERSION" ] && [ "$LATEST_RELEASE" != "$CURRENT_VERSION" ]; then
        info "New distro release: $LATEST_RELEASE (was: $CURRENT_VERSION)"
        notify_user \
            "Mint Arch Linux $LATEST_RELEASE Available" \
            "A new Mint Arch Linux release is out. Your packages are auto-updated via pacman.\nA fresh ISO is optional for new bundled features.\nhttps://github.com/og-py3/mint-arch-linux/releases/latest" \
            "system-upgrade"
    else
        info "On latest release: $LATEST_RELEASE"
    fi
fi

info "=================================================="
info "Auto-updater finished."
info "=================================================="