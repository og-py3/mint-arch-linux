#!/usr/bin/env bash
# =============================================================================
# Mint OS — mint-clean  |  Intelligent system cleaner
# =============================================================================
set -euo pipefail

LOG_DIR="/var/log/mint-os"; mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/mint-clean-$(date +%Y%m%d-%H%M%S).log"
exec > >(tee -a "$LOG") 2>&1

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'
MINT='\033[38;2;46;203;113m'

info()    { echo -e "${MINT}[+]${NC} $*"; }
warn()    { echo -e "${YELLOW}[!]${NC} $*"; }
section() { echo -e "\n${BOLD}${CYAN}── $* ──${NC}"; }
saved()   { echo -e "${GREEN}[✓]${NC} Freed: ${BOLD}$1${NC}"; }

check_root() { [[ "$EUID" -eq 0 ]] || { echo -e "${RED}Run as root: sudo mint-clean${NC}"; exit 1; }; }

banner() {
    echo -e "${MINT}${BOLD}"
    echo "  ╔═══════════════════════════════╗"
    echo "  ║   Mint OS System Cleaner      ║"
    echo "  ╚═══════════════════════════════╝${NC}"
    echo ""
}

clean_pacman_cache() {
    section "Package Cache"
    local before after
    before=$(du -sh /var/cache/pacman/pkg/ 2>/dev/null | cut -f1)
    info "Keeping last 2 versions of each package..."
    paccache -rk2 --noconfirm
    info "Removing uninstalled package cache..."
    paccache -ruk0 --noconfirm
    after=$(du -sh /var/cache/pacman/pkg/ 2>/dev/null | cut -f1)
    saved "$before → $after"
}

clean_orphans() {
    section "Orphaned Packages"
    local orphans
    orphans=$(pacman -Qdtq 2>/dev/null || true)
    if [[ -n "$orphans" ]]; then
        echo "$orphans"
        read -r -p "Remove orphaned packages? [y/N]: " confirm
        [[ "$confirm" =~ ^[Yy]$ ]] && pacman -Rns $orphans --noconfirm
        info "Orphans removed."
    else
        info "No orphaned packages."
    fi
}

clean_journal() {
    section "System Journal"
    local before after
    before=$(journalctl --disk-usage 2>/dev/null | grep -o '[0-9.]*[MGK]B' | head -1)
    journalctl --vacuum-size=256M --vacuum-time=2weeks
    after=$(journalctl --disk-usage 2>/dev/null | grep -o '[0-9.]*[MGK]B' | head -1)
    saved "$before → $after"
}

clean_tmp() {
    section "Temporary Files"
    local size
    size=$(du -sh /tmp 2>/dev/null | cut -f1)
    find /tmp -maxdepth 1 -mtime +3 -exec rm -rf {} + 2>/dev/null || true
    find /var/tmp -maxdepth 1 -mtime +7 -exec rm -rf {} + 2>/dev/null || true
    saved "~$size from /tmp"
}

clean_user_cache() {
    section "User Cache"
    local real_user="${SUDO_USER:-}"
    if [[ -n "$real_user" ]]; then
        local home
        home=$(getent passwd "$real_user" | cut -d: -f6)
        local before
        before=$(du -sh "$home/.cache" 2>/dev/null | cut -f1)
        find "$home/.cache" -maxdepth 2 -atime +30 -exec rm -rf {} + 2>/dev/null || true
        local after
        after=$(du -sh "$home/.cache" 2>/dev/null | cut -f1)
        saved "$before → $after"
    fi
}

clean_flatpak() {
    section "Flatpak Unused Runtimes"
    if command -v flatpak &>/dev/null; then
        local before
        before=$(flatpak list --runtime 2>/dev/null | wc -l)
        flatpak uninstall --unused --noninteractive 2>/dev/null || true
        local after
        after=$(flatpak list --runtime 2>/dev/null | wc -l)
        saved "$((before - after)) unused runtimes removed"
    else
        info "Flatpak not installed — skipping."
    fi
}

clean_btrfs_snapshots() {
    section "Old Btrfs Snapshots"
    if command -v snapper &>/dev/null && findmnt -n -o FSTYPE / | grep -q btrfs; then
        info "Removing snapshots older than 30 days..."
        snapper -c root cleanup --type number 2>/dev/null || true
        info "Snapshot cleanup done."
    else
        info "Btrfs/Snapper not active — skipping."
    fi
}

show_summary() {
    section "Summary"
    echo -e "  ${BOLD}Current disk usage:${NC}"
    df -h / /home 2>/dev/null | tail -n +2 | while read -r line; do
        echo "  $line"
    done
    echo ""
    info "Log saved: $LOG"
}

main() {
    banner
    check_root
    clean_pacman_cache
    clean_orphans
    clean_journal
    clean_tmp
    clean_user_cache
    clean_flatpak
    clean_btrfs_snapshots
    show_summary
    echo -e "\n${MINT}${BOLD}Mint OS clean complete!${NC}\n"
}

main "$@"
