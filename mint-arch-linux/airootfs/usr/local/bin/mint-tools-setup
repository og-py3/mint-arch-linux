#!/usr/bin/env bash
# =============================================================================
# Mint OS - Security Tools Manager
# Installs security tool categories from official Arch Linux repositories
# All tools are sourced from [core], [extra], [community], and AUR only.
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

banner() {
    echo -e "${CYAN}"
    echo "  ███╗   ███╗██╗███╗   ██╗████████╗     ██████╗ ███████╗"
    echo "  ████╗ ████║██║████╗  ██║╚══██╔══╝    ██╔═══██╗██╔════╝"
    echo "  ██╔████╔██║██║██╔██╗ ██║   ██║       ██║   ██║███████╗"
    echo "  ██║╚██╔╝██║██║██║╚██╗██║   ██║       ██║   ██║╚════██║"
    echo "  ██║ ╚═╝ ██║██║██║ ╚████║   ██║       ╚██████╔╝███████║"
    echo "  ╚═╝     ╚═╝╚═╝╚═╝  ╚═══╝   ╚═╝        ╚═════╝ ╚══════╝"
    echo -e "${NC}"
    echo -e "${BOLD}  Mint OS Security Tools Manager${NC}"
    echo "  ─────────────────────────────────────"
    echo ""
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}[!] Please run as root: sudo mint-tools-setup${NC}"
        exit 1
    fi
}

install_pkgs() {
    local label="$1"; shift
    local pkgs=("$@")
    echo -e "${GREEN}[+] Installing: ${BOLD}$label${NC}"
    pacman -S --needed --noconfirm "${pkgs[@]}" 2>/dev/null || {
        echo -e "${YELLOW}[!] Some packages unavailable in official repos — trying AUR via paru...${NC}"
        if command -v paru &>/dev/null; then
            local real_user="${SUDO_USER:-}"
            [[ -n "$real_user" ]] && sudo -u "$real_user" paru -S --needed --noconfirm "${pkgs[@]}" 2>/dev/null || true
        fi
    }
}

# ─── Tool Categories ─────────────────────────────────────────────────────────

cat_info_gathering() {
    install_pkgs "Information Gathering" \
        nmap masscan netdiscover arp-scan whois dnsutils bind traceroute \
        mtr tcptraceroute tcpflow p0f smbmap enum4linux smbclient \
        nbtscan onesixtyone snmpwalk fping hping
}

cat_recon() {
    install_pkgs "Reconnaissance" \
        amass subfinder httpx-toolkit nuclei waybackurls \
        whatweb wafw00f wpscan dnsrecon fierce dnsenum \
        theharvester spiderfoot maltego
}

cat_web_apps() {
    install_pkgs "Web Application Testing" \
        sqlmap nikto dirb gobuster ffuf wfuzz \
        burpsuite zaproxy xsser wapiti commix \
        curl wget httpie python-requests \
        skipfish w3af
}

cat_password() {
    install_pkgs "Password & Hash Cracking" \
        hashcat john hydra medusa \
        crunch cewl wordlistctl \
        ophcrack samdump2 chntpw \
        pdfcrack fcrackzip rarcrack \
        hash-identifier hashid
}

cat_wireless() {
    install_pkgs "Wireless & WiFi" \
        aircrack-ng kismet wireshark-qt wireshark-cli \
        bettercap mdk4 pixiewps reaver \
        hcxdumptool hcxtools \
        iw wireless_tools wavemon
}

cat_exploitation() {
    install_pkgs "Exploitation" \
        metasploit exploitdb beef \
        pwntools python-impacket \
        python-pycryptodome python-paramiko \
        searchsploit
}

cat_post_exploit() {
    install_pkgs "Post-Exploitation" \
        bloodhound neo4j \
        crackmapexec evil-winrm \
        python-impacket smbmap \
        pwncat nc socat
}

cat_forensics() {
    install_pkgs "Forensics & Recovery" \
        autopsy sleuthkit binwalk foremost \
        testdisk photorec extundelete dc3dd \
        ddrescue guymager \
        exiftool bulk-extractor \
        volatility3 rekall
}

cat_reversing() {
    install_pkgs "Reverse Engineering" \
        radare2 ghidra cutter \
        gdb gef pwndbg \
        ltrace strace valgrind \
        apktool dex2jar jadx \
        r2ghidra
}

cat_sniffing() {
    install_pkgs "Sniffing & Spoofing" \
        wireshark-qt tcpdump dsniff \
        ettercap bettercap responder \
        arpwatch arping \
        mitmproxy sslstrip \
        netsed
}

cat_network() {
    install_pkgs "Network Tools" \
        ncat netcat socat \
        proxychains-ng tor torsocks \
        openvpn wireguard-tools \
        sslscan testssl.sh sslyze \
        openssl gnutls-utils
}

cat_crypto() {
    install_pkgs "Cryptography & Steganography" \
        steghide stegseek \
        exiftool openssl \
        age gnupg \
        hashcat john \
        xortool
}

cat_osint() {
    install_pkgs "OSINT" \
        maltego recon-ng theharvester \
        sherlock phoneinfoga \
        spiderfoot amass \
        python-shodan photon
}

cat_social_eng() {
    install_pkgs "Social Engineering" \
        set gophish \
        msfconsole
}

cat_fuzzing() {
    install_pkgs "Fuzzing" \
        ffuf wfuzz radamsa \
        american-fuzzy-lop honggfuzz \
        boofuzz python-atheris
}

cat_container() {
    install_pkgs "Container Security" \
        docker trivy \
        dive grype \
        hadolint syft \
        kubectl helm
}

cat_mobile() {
    install_pkgs "Mobile Security" \
        apktool dex2jar jadx \
        frida python-frida-tools \
        adb fastboot \
        androguard
}

cat_voip() {
    install_pkgs "VoIP" \
        sipvicious svcrack \
        sipsak python-scapy \
        wireshark-qt
}

cat_defensive() {
    install_pkgs "Defensive & Monitoring" \
        snort suricata \
        zeek ossec-hids \
        aide rkhunter chkrootkit \
        lynis clamav \
        auditd
}

cat_database() {
    install_pkgs "Database Attacks" \
        sqlmap \
        python-pymysql \
        python-psycopg2 \
        mongoclient \
        redis-tools
}

cat_firmware() {
    install_pkgs "Firmware Analysis" \
        binwalk flashrom \
        openocd avrdude \
        esptool \
        qemu-full \
        firmwalker
}

cat_misc() {
    install_pkgs "Miscellaneous Tools" \
        tor torsocks proxychains-ng \
        openvpn wireguard-tools \
        python-pwntools \
        pwncat tmux screen \
        neovim vim \
        python-scapy
}

# ─── Menu ────────────────────────────────────────────────────────────────────

show_menu() {
    echo -e "${BOLD}Select Mint OS security tool category:${NC}"
    echo ""
    echo "  1)  Information Gathering"
    echo "  2)  Reconnaissance & OSINT"
    echo "  3)  Web Application Testing"
    echo "  4)  Password & Hash Cracking"
    echo "  5)  Wireless & WiFi"
    echo "  6)  Exploitation"
    echo "  7)  Post-Exploitation"
    echo "  8)  Forensics & Recovery"
    echo "  9)  Reverse Engineering"
    echo "  10) Sniffing & Spoofing"
    echo "  11) Network Tools"
    echo "  12) Cryptography & Steganography"
    echo "  13) OSINT"
    echo "  14) Social Engineering"
    echo "  15) Fuzzing"
    echo "  16) Container Security"
    echo "  17) Mobile Security"
    echo "  18) VoIP"
    echo "  19) Defensive & Monitoring"
    echo "  20) Database Attacks"
    echo "  21) Firmware Analysis"
    echo "  22) Miscellaneous"
    echo "  A)  Install ALL categories"
    echo "  Q)  Quit"
    echo ""
}

install_all() {
    echo -e "${YELLOW}[!] Installing ALL tool categories. This will take a while.${NC}"
    read -r -p "Are you sure? (y/N): " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || return
    cat_info_gathering; cat_recon; cat_web_apps; cat_password
    cat_wireless; cat_exploitation; cat_post_exploit; cat_forensics
    cat_reversing; cat_sniffing; cat_network; cat_crypto
    cat_osint; cat_social_eng; cat_fuzzing; cat_container
    cat_mobile; cat_voip; cat_defensive; cat_database
    cat_firmware; cat_misc
}

main() {
    banner
    check_root

    while true; do
        show_menu
        read -r -p "Choice: " choice
        echo ""
        case "$choice" in
            1)  cat_info_gathering ;;
            2)  cat_recon ;;
            3)  cat_web_apps ;;
            4)  cat_password ;;
            5)  cat_wireless ;;
            6)  cat_exploitation ;;
            7)  cat_post_exploit ;;
            8)  cat_forensics ;;
            9)  cat_reversing ;;
            10) cat_sniffing ;;
            11) cat_network ;;
            12) cat_crypto ;;
            13) cat_osint ;;
            14) cat_social_eng ;;
            15) cat_fuzzing ;;
            16) cat_container ;;
            17) cat_mobile ;;
            18) cat_voip ;;
            19) cat_defensive ;;
            20) cat_database ;;
            21) cat_firmware ;;
            22) cat_misc ;;
            [Aa]) install_all ;;
            [Qq]) echo -e "${GREEN}Goodbye!${NC}"; exit 0 ;;
            *) echo -e "${RED}[!] Invalid choice.${NC}" ;;
        esac
        echo ""
    done
}

main "$@"
