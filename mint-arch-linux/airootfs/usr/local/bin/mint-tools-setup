install_all_kali() {
    echo ""
    echo -e "${MINT}${BOLD}Installing ALL Kali Linux equivalent tools...${NC}"
    echo -e "${CYAN}This maps all Kali metapackages to BlackArch equivalents.${NC}"
    echo ""
    kali_info_gathering
    kali_vulnerability
    kali_web_apps
    kali_passwords
    kali_wireless
    kali_reverse_engineering
    kali_exploitation
    kali_sniffing_spoofing
    kali_post_exploitation
    kali_forensics
    kali_reporting
    kali_social_engineering
    kali_osint
    kali_cloud
    kali_hardware
    echo ""
    echo -e "${GREEN}${BOLD}All Kali-equivalent tools installed!${NC}"
}

install_all_blackarch() {
    echo ""
    echo -e "${MINT}${BOLD}Installing ALL BlackArch groups (2800+ tools)...${NC}"
    echo -e "${YELLOW}Warning: This requires ~50GB disk space and several hours.${NC}"
    echo ""
    read -r -p "Continue? [y/N]: " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || exit 0
    install_group "ALL BlackArch Tools" blackarch
}

# =============================================================================
# INTERACTIVE MENU
# =============================================================================

show_menu() {
    echo -e "${BOLD}Choose what to install:${NC}"
    echo ""
    echo -e "  ${CYAN}[1]${NC}  All Kali Linux equivalent tools         ${YELLOW}(recommended, ~5-15GB)${NC}"
    echo -e "  ${CYAN}[2]${NC}  All BlackArch tools (2800+)             ${YELLOW}(full suite, ~50GB)${NC}"
    echo ""
    echo -e "  ${CYAN}── Kali Categories ──────────────────────────────────────${NC}"
    echo -e "  ${CYAN}[3]${NC}  Information Gathering"
    echo -e "  ${CYAN}[4]${NC}  Vulnerability Scanning"
    echo -e "  ${CYAN}[5]${NC}  Web Application Testing"
    echo -e "  ${CYAN}[6]${NC}  Password & Hash Cracking"
    echo -e "  ${CYAN}[7]${NC}  Wireless & WiFi"
    echo -e "  ${CYAN}[8]${NC}  Reverse Engineering"
    echo -e "  ${CYAN}[9]${NC}  Exploitation Frameworks"
    echo -e "  ${CYAN}[10]${NC} Sniffing & Spoofing"
    echo -e "  ${CYAN}[11]${NC} Post-Exploitation"
    echo -e "  ${CYAN}[12]${NC} Forensics & Recovery"
    echo -e "  ${CYAN}[13]${NC} Social Engineering"
    echo -e "  ${CYAN}[14]${NC} OSINT"
    echo -e "  ${CYAN}[15]${NC} Cloud & Container Security"
    echo -e "  ${CYAN}[16]${NC} Hardware & IoT"
    echo ""
    echo -e "  ${CYAN}── BlackArch Groups ─────────────────────────────────────${NC}"
    echo -e "  ${CYAN}[17]${NC} Exploitation (BlackArch)"
    echo -e "  ${CYAN}[18]${NC} Fuzzers"
    echo -e "  ${CYAN}[19]${NC} Forensics (BlackArch)"
    echo -e "  ${CYAN}[20]${NC} Scanners"
    echo -e "  ${CYAN}[21]${NC} Malware Analysis"
    echo -e "  ${CYAN}[22]${NC} Backdoors"
    echo -e "  ${CYAN}[23]${NC} Honeypots"
    echo -e "  ${CYAN}[24]${NC} IDS / IPS"
    echo -e "  ${CYAN}[25]${NC} VoIP Security"
    echo -e "  ${CYAN}[26]${NC} Windows / Active Directory"
    echo -e "  ${CYAN}[27]${NC} Hardware Hacking (BlackArch)"
    echo -e "  ${CYAN}[28]${NC} Firmware Analysis"
    echo -e "  ${CYAN}[29]${NC} NFC & RFID"
    echo -e "  ${CYAN}[30]${NC} Drone / RF Hacking"
    echo ""
    echo -e "  ${CYAN}[q]${NC}  Quit"
    echo ""
    read -r -p "  Choice: " choice
    echo ""

    case "$choice" in
        1)  install_all_kali ;;
        2)  install_all_blackarch ;;
        3)  kali_info_gathering ;;
        4)  kali_vulnerability ;;
        5)  kali_web_apps ;;
        6)  kali_passwords ;;
        7)  kali_wireless ;;
        8)  kali_reverse_engineering ;;
        9)  kali_exploitation ;;
        10) kali_sniffing_spoofing ;;
        11) kali_post_exploitation ;;
        12) kali_forensics ;;
        13) kali_social_engineering ;;
        14) kali_osint ;;
        15) kali_cloud ;;
        16) kali_hardware ;;
        17) cat_exploitation ;;
        18) cat_fuzzer ;;
        19) cat_forensic ;;
        20) cat_scanner ;;
        21) cat_malware ;;
        22) cat_backdoor ;;
        23) cat_honeypot ;;
        24) cat_ids ;;
        25) cat_voip ;;
        26) cat_windows ;;
        27) cat_hardware ;;
        28) cat_firmware ;;
        29) cat_nfc ;;
        30) cat_drone ;;
        q|Q) echo "Bye!"; exit 0 ;;
        *) echo -e "${RED}Invalid choice${NC}" ;;
    esac
}

# =============================================================================
# MAIN
# =============================================================================

main() {
    banner
    check_root
    ensure_blackarch

    # Non-interactive: pass category as argument
    if [ "$#" -gt 0 ]; then
        case "$1" in
            --all-kali)       install_all_kali ;;
            --all-blackarch)  install_all_blackarch ;;
            --info)           kali_info_gathering ;;
            --vuln)           kali_vulnerability ;;
            --web)            kali_web_apps ;;
            --passwords)      kali_passwords ;;
            --wireless)       kali_wireless ;;
            --reversing)      kali_reverse_engineering ;;
            --exploit)        kali_exploitation ;;
            --sniff)          kali_sniffing_spoofing ;;
            --postexploit)    kali_post_exploitation ;;
            --forensics)      kali_forensics ;;
            --social)         kali_social_engineering ;;
            --osint)          kali_osint ;;
            --cloud)          kali_cloud ;;
            --hardware)       kali_hardware ;;
            *)
                echo "Usage: mint-tools-setup [--all-kali] [--all-blackarch]"
                echo "       [--info] [--vuln] [--web] [--passwords] [--wireless]"
                echo "       [--reversing] [--exploit] [--sniff] [--postexploit]"
                echo "       [--forensics] [--social] [--osint] [--cloud] [--hardware]"
                exit 1
                ;;
        esac
        exit 0
    fi

    # Interactive menu (loop)
    while true; do
        show_menu
        echo ""
        read -r -p "Install more? [y/N]: " again
        [[ "$again" =~ ^[Yy]$ ]] || break
    done

    echo ""
    echo -e "${GREEN}${BOLD}Done! All selected tools installed.${NC}"
    echo -e "${CYAN}Tip: Run${NC} sudo mint-tools-setup --all-kali ${CYAN}to install everything non-interactively.${NC}"
    echo ""
}

main "$@"