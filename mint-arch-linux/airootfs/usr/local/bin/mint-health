#!/usr/bin/env bash
# =============================================================================
# Mint OS - System Health Dashboard
# Displays CPU temps, drive health, memory, uptime, and more
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

divider() { echo -e "${CYAN}  ─────────────────────────────────────────${NC}"; }
label()   { printf "  ${BOLD}%-20s${NC}" "$1:"; }
ok()      { echo -e "${GREEN}$*${NC}"; }
warn()    { echo -e "${YELLOW}$*${NC}"; }
bad()     { echo -e "${RED}$*${NC}"; }

banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ╔════════════════════════════════════════════╗"
    echo "  ║       Mint OS System Health Dashboard      ║"
    echo "  ╚════════════════════════════════════════════╝"
    echo -e "  ${NC}$(date '+%A, %B %d %Y  %H:%M:%S')${NC}"
    echo ""
}

show_uptime() {
    divider
    echo -e "  ${BOLD}${BLUE}System${NC}"
    divider
    label "Hostname"; echo "$(hostname)"
    label "OS";       cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d= -f2 | tr -d '"'
    label "Kernel";   uname -r
    label "Uptime";   uptime -p
    label "Load Avg"; uptime | awk -F'load average:' '{print $2}' | xargs
}

show_cpu() {
    divider
    echo -e "  ${BOLD}${BLUE}CPU${NC}"
    divider

    local cpu_model
    cpu_model=$(grep "model name" /proc/cpuinfo | head -1 | cut -d: -f2 | xargs)
    label "Model";   echo "$cpu_model"

    local cores
    cores=$(nproc)
    label "Cores";   echo "$cores"

    local cpu_usage
    cpu_usage=$(top -bn1 | grep "Cpu(s)" | awk '{print $2}' | cut -d'%' -f1 2>/dev/null || echo "N/A")
    label "Usage";
    if [[ "$cpu_usage" =~ ^[0-9] ]]; then
        local usage_int=${cpu_usage%.*}
        if (( usage_int > 80 )); then bad "${cpu_usage}% (HIGH)"
        elif (( usage_int > 50 )); then warn "${cpu_usage}% (MODERATE)"
        else ok "${cpu_usage}%"
        fi
    else
        echo "$cpu_usage"
    fi

    # CPU Temperature
    if command -v sensors &>/dev/null; then
        local cpu_temp
        cpu_temp=$(sensors 2>/dev/null | grep -E "Core 0|Tctl|Package" | head -1 | awk '{print $3}' | tr -d '+')
        label "Temp";
        if [[ -n "$cpu_temp" ]]; then
            local temp_val
            temp_val=$(echo "$cpu_temp" | grep -o '[0-9]*\.' | head -1 | tr -d '.')
            if [[ -n "$temp_val" ]] && (( temp_val > 80 )); then bad "$cpu_temp (HOT!)"
            elif [[ -n "$temp_val" ]] && (( temp_val > 65 )); then warn "$cpu_temp (WARM)"
            else ok "$cpu_temp"
            fi
        else
            echo "N/A (run: sudo modprobe coretemp)"
        fi
    fi
}

show_memory() {
    divider
    echo -e "  ${BOLD}${BLUE}Memory${NC}"
    divider

    local total used free avail
    total=$(free -h | awk '/Mem:/{print $2}')
    used=$(free -h  | awk '/Mem:/{print $3}')
    avail=$(free -h | awk '/Mem:/{print $7}')
    local swap_total swap_used
    swap_total=$(free -h | awk '/Swap:/{print $2}')
    swap_used=$(free -h  | awk '/Swap:/{print $3}')

    local used_pct
    used_pct=$(free | awk '/Mem:/{printf "%.0f", $3/$2*100}')

    label "RAM Total"; echo "$total"
    label "RAM Used";
    if (( used_pct > 85 )); then bad "$used / $total (${used_pct}% — HIGH)"
    elif (( used_pct > 60 )); then warn "$used / $total (${used_pct}%)"
    else ok "$used / $total (${used_pct}%)"
    fi
    label "Available"; ok "$avail"
    label "Swap";

    if [[ "$swap_total" == "0B" ]]; then
        warn "No swap configured"
    else
        echo "$swap_used / $swap_total"
    fi
}

show_disks() {
    divider
    echo -e "  ${BOLD}${BLUE}Storage${NC}"
    divider

    df -h --output=target,size,used,avail,pcent | grep -v "tmpfs\|devtmpfs\|efivarfs" | tail -n +2 | while read -r mount size used avail pct; do
        local pct_val=${pct//%/}
        printf "  ${BOLD}%-20s${NC}" "$mount"
        if (( pct_val > 90 )); then bad "$used/$size (${pct} — CRITICAL)"
        elif (( pct_val > 75 )); then warn "$used/$size (${pct})"
        else ok "$used/$size (${pct})"
        fi
    done

    # SMART health
    if command -v smartctl &>/dev/null; then
        echo ""
        echo -e "  ${BOLD}Drive Health (SMART):${NC}"
        for disk in /dev/sd? /dev/nvme?; do
            [ -b "$disk" ] || continue
            local health
            health=$(smartctl -H "$disk" 2>/dev/null | grep "overall-health\|SMART Health" | awk '{print $NF}' || echo "Unknown")
            printf "  %-20s" "$disk:"
            if [[ "$health" == "PASSED" ]] || [[ "$health" == "OK" ]]; then
                ok "$health"
            else
                bad "$health"
            fi
        done
    fi
}

show_network() {
    divider
    echo -e "  ${BOLD}${BLUE}Network${NC}"
    divider

    # Active interfaces
    ip -br addr | grep -v "^lo" | while read -r iface state addr; do
        printf "  ${BOLD}%-20s${NC}" "$iface"
        if [[ "$state" == "UP" ]]; then
            ok "UP  $addr"
        else
            warn "DOWN"
        fi
    done

    label "Public IP"
    local pubip
    pubip=$(curl -s --max-time 3 ifconfig.me 2>/dev/null || echo "offline")
    echo "$pubip"

    # Firewall status
    label "Firewall"
    if command -v ufw &>/dev/null; then
        local ufw_status
        ufw_status=$(ufw status 2>/dev/null | head -1)
        if echo "$ufw_status" | grep -q "active"; then ok "ufw active"
        else warn "ufw inactive"
        fi
    else
        warn "ufw not installed"
    fi
}

show_security() {
    divider
    echo -e "  ${BOLD}${BLUE}Security Status${NC}"
    divider

    # AppArmor
    label "AppArmor"
    if command -v aa-status &>/dev/null; then
        local enforced
        enforced=$(aa-status 2>/dev/null | grep "profiles are in enforce mode" | awk '{print $1}' || echo "0")
        if [[ "$enforced" -gt 0 ]] 2>/dev/null; then ok "Active ($enforced profiles enforcing)"
        else warn "Installed but 0 profiles enforcing"
        fi
    else
        bad "Not installed (run: sudo mint-privacy)"
    fi

    # Fail2ban
    label "Fail2ban"
    if systemctl is-active --quiet fail2ban 2>/dev/null; then
        ok "Active"
    else
        warn "Inactive"
    fi

    # SSH
    label "SSH"
    if systemctl is-active --quiet sshd 2>/dev/null; then
        local root_login
        root_login=$(grep "PermitRootLogin" /etc/ssh/sshd_config 2>/dev/null | grep -v "^#" | awk '{print $2}' | head -1)
        if [[ "$root_login" == "no" ]]; then ok "Running (root login: disabled)"
        else warn "Running (root login: ${root_login:-check config})"
        fi
    else
        ok "Stopped (not exposed)"
    fi

    # Last logins
    echo ""
    echo -e "  ${BOLD}Last 5 Logins:${NC}"
    last -5 2>/dev/null | head -5 | while read -r line; do
        echo "    $line"
    done
}

show_updates() {
    divider
    echo -e "  ${BOLD}${BLUE}Pending Updates${NC}"
    divider

    local count
    count=$(checkupdates 2>/dev/null | wc -l || echo "0")
    label "Pacman"
    if (( count > 50 )); then bad "$count packages (update soon)"
    elif (( count > 0 )); then warn "$count packages available"
    else ok "Up to date"
    fi

    if command -v paru &>/dev/null; then
        label "AUR"
        local real_user="${SUDO_USER:-$USER}"
        local aur_count
        aur_count=$(sudo -u "$real_user" paru -Qua 2>/dev/null | wc -l || echo "?")
        echo "$aur_count packages"
    fi
}

main() {
    banner
    show_uptime
    show_cpu
    show_memory
    show_disks
    show_network
    show_security
    show_updates
    divider
    echo ""
    echo -e "  Run ${BOLD}sudo mint-update${NC} to update | ${BOLD}sudo mint-privacy${NC} to harden"
    echo ""
}

main "$@"
