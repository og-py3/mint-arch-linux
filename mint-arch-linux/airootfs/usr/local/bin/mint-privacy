#!/usr/bin/env bash
# =============================================================================
# Mint OS - Privacy & Security Hardening Script
# One-command system privacy lockdown
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${GREEN}[+]${NC} $*"; }
warn()    { echo -e "${YELLOW}[!]${NC} $*"; }
ok()      { echo -e "${GREEN}[✓]${NC} $*"; }
section() { echo -e "\n${BOLD}${CYAN}── $* ──${NC}\n"; }

check_root() {
    [[ "$EUID" -eq 0 ]] || { echo -e "${RED}Run as root: sudo mint-privacy${NC}"; exit 1; }
}

banner() {
    echo -e "${CYAN}${BOLD}"
    echo "  Mint OS Privacy & Security Hardening"
    echo -e "${NC}"
    echo "  This script hardens your system with privacy best practices."
    echo "  All changes are logged to /var/log/mint-privacy.log"
    echo ""
}

setup_firewall() {
    section "Firewall Setup (ufw)"
    pacman -S --needed --noconfirm ufw

    ufw default deny incoming
    ufw default allow outgoing
    ufw allow ssh
    ufw --force enable
    systemctl enable ufw

    ok "Firewall enabled: deny all incoming, allow outgoing, SSH allowed"
}

setup_dns_over_https() {
    section "DNS-over-HTTPS (dnscrypt-proxy)"
    pacman -S --needed --noconfirm dnscrypt-proxy

    # Configure to use Cloudflare + Quad9
    cat > /etc/dnscrypt-proxy/dnscrypt-proxy.toml <<'DNSCRYPT'
listen_addresses = ['127.0.0.1:5300', '[::1]:5300']
max_clients = 250
ipv4_servers = true
ipv6_servers = false
dnscrypt_servers = true
doh_servers = true
require_nolog = true
require_nofilter = false
server_names = ['cloudflare', 'cloudflare-ipv6', 'quad9-dnscrypt-ip4-filter-pri']
fallback_resolvers = ['9.9.9.9:53', '8.8.8.8:53']
ignore_system_dns = true
netprobe_timeout = 60

[sources]
  [sources.'public-resolvers']
  urls = ['https://raw.githubusercontent.com/DNSCrypt/dnscrypt-resolvers/master/v3/public-resolvers.md']
  cache_file = '/var/cache/dnscrypt-proxy/public-resolvers.md'
  minisign_key = 'RWQf6LRCGA9i53mlYecO4IzT51TGPpvWucNSCh1CBM0QTaLn73Y7GFO3'
  refresh_delay = 72
DNSCRYPT

    systemctl enable dnscrypt-proxy
    systemctl start dnscrypt-proxy

    # Tell NetworkManager to use local dnscrypt proxy
    cat > /etc/NetworkManager/conf.d/dns.conf <<'NM'
[main]
dns=none
NM

    echo "nameserver 127.0.0.1" > /etc/resolv.conf
    chattr +i /etc/resolv.conf  # Prevent NM from overwriting it

    ok "DNS-over-HTTPS enabled via dnscrypt-proxy"
}

harden_kernel() {
    section "Kernel Security Hardening"

    cat > /etc/sysctl.d/99-mint-hardening.conf <<'SYSCTL'
# Mint OS Kernel Hardening

# Disable IP forwarding (not a router)
net.ipv4.ip_forward = 0
net.ipv6.conf.all.forwarding = 0

# Disable source routing
net.ipv4.conf.all.accept_source_route = 0
net.ipv4.conf.default.accept_source_route = 0

# Disable ICMP redirects
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0
net.ipv4.conf.all.send_redirects = 0
net.ipv6.conf.all.accept_redirects = 0

# Enable SYN flood protection
net.ipv4.tcp_syncookies = 1
net.ipv4.tcp_syn_retries = 2
net.ipv4.tcp_synack_retries = 2

# Disable IPv6 if not needed
# net.ipv6.conf.all.disable_ipv6 = 1

# Restrict dmesg to root
kernel.dmesg_restrict = 1

# Restrict ptrace
kernel.yama.ptrace_scope = 1

# Disable kernel module loading after boot
# kernel.modules_disabled = 1

# Hide kernel pointers from non-root
kernel.kptr_restrict = 2

# Enable ASLR
kernel.randomize_va_space = 2

# Disable core dumps
fs.suid_dumpable = 0
kernel.core_uses_pid = 1

# Restrict /proc
kernel.perf_event_paranoid = 3
SYSCTL

    sysctl -p /etc/sysctl.d/99-mint-hardening.conf
    ok "Kernel hardening applied (ASLR, ptrace restriction, SYN flood protection)"
}

setup_apparmor() {
    section "AppArmor (Mandatory Access Control)"
    pacman -S --needed --noconfirm apparmor

    systemctl enable apparmor
    systemctl start apparmor

    # Set AppArmor enforce mode for all profiles
    aa-enforce /etc/apparmor.d/* 2>/dev/null || true

    # Add AppArmor to GRUB
    if [ -f /etc/default/grub ]; then
        if ! grep -q "apparmor=1" /etc/default/grub; then
            sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="/GRUB_CMDLINE_LINUX_DEFAULT="apparmor=1 security=apparmor /' \
                /etc/default/grub
            grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null || true
        fi
    fi

    ok "AppArmor enabled and enforcing"
}

disable_telemetry() {
    section "Disabling Telemetry & Tracking"

    # Disable systemd OOMD (sends usage data)
    systemctl disable --now systemd-oomd 2>/dev/null || true

    # Disable avahi-daemon mDNS broadcast (optional privacy)
    # systemctl disable avahi-daemon

    # Firefox privacy hardening (if installed)
    if command -v firefox &>/dev/null; then
        info "Applying Firefox privacy settings..."
        local ff_dir="/usr/lib/firefox"
        mkdir -p "$ff_dir"
        cat > "$ff_dir/mozilla.cfg" <<'FFCFG'
// Mint OS Firefox Privacy Config
lockPref("toolkit.telemetry.enabled", false);
lockPref("toolkit.telemetry.unified", false);
lockPref("toolkit.telemetry.archive.enabled", false);
lockPref("datareporting.policy.dataSubmissionEnabled", false);
lockPref("datareporting.healthreport.uploadEnabled", false);
lockPref("browser.crashReports.unsubmittedCheck.enabled", false);
lockPref("browser.tabs.crashReporting.sendReport", false);
lockPref("browser.safebrowsing.phishing.enabled", false);
lockPref("browser.safebrowsing.malware.enabled", false);
lockPref("network.prefetch-next", false);
lockPref("network.dns.disablePrefetch", true);
lockPref("network.predictor.enabled", false);
lockPref("privacy.trackingprotection.enabled", true);
lockPref("privacy.trackingprotection.socialtracking.enabled", true);
FFCFG

        cat > "$ff_dir/defaults/pref/autoconfig.js" <<'AUTOCONF'
pref("general.config.filename", "mozilla.cfg");
pref("general.config.obscure_value", 0);
AUTOCONF
        ok "Firefox telemetry disabled"
    fi

    ok "System telemetry disabled"
}

secure_ssh() {
    section "SSH Hardening"
    if [ -f /etc/ssh/sshd_config ]; then
        cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak

        cat > /etc/ssh/sshd_config.d/99-mint-hardening.conf <<'SSH'
# Mint OS SSH Hardening
Protocol 2
PermitRootLogin no
MaxAuthTries 3
PubkeyAuthentication yes
PasswordAuthentication yes
PermitEmptyPasswords no
X11Forwarding no
AllowAgentForwarding no
ClientAliveInterval 300
ClientAliveCountMax 2
LoginGraceTime 30
SSH
        ok "SSH hardened (root login disabled, max 3 auth tries)"
    fi
}

setup_fail2ban() {
    section "Fail2ban (Brute Force Protection)"
    pacman -S --needed --noconfirm fail2ban

    cat > /etc/fail2ban/jail.d/mint.conf <<'F2B'
[DEFAULT]
bantime  = 1h
findtime = 10m
maxretry = 5
backend = systemd

[sshd]
enabled = true
port    = ssh
filter  = sshd
maxretry = 3
F2B

    systemctl enable fail2ban
    systemctl start fail2ban
    ok "Fail2ban active — brute force protection enabled"
}

show_summary() {
    section "Privacy Hardening Complete"
    echo ""
    echo -e "  ${BOLD}What was applied:${NC}"
    echo "  [✓] Firewall (ufw) — deny all incoming"
    echo "  [✓] DNS-over-HTTPS (dnscrypt-proxy)"
    echo "  [✓] Kernel hardening (ASLR, ptrace restrictions, SYN cookies)"
    echo "  [✓] AppArmor MAC enforcement"
    echo "  [✓] Telemetry disabled (system + Firefox)"
    echo "  [✓] SSH hardened"
    echo "  [✓] Fail2ban brute force protection"
    echo ""
    warn "A reboot is recommended to apply all kernel changes."
}

main() {
    banner
    check_root

    setup_firewall
    setup_dns_over_https
    harden_kernel
    setup_apparmor
    disable_telemetry
    secure_ssh
    setup_fail2ban
    show_summary
}

main "$@"
