#!/usr/bin/env bash
# =============================================================================
# Mint Arch Linux — mint-welcome  |  First-run welcome wizard (CLI)
# =============================================================================
set -euo pipefail

MINT='\033[38;2;46;203;113m'; BOLD='\033[1m'; NC='\033[0m'
CYAN='\033[0;36m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
DONE_FILE="$HOME/.config/mint-welcomed"

[[ -f "$DONE_FILE" ]] && exit 0

clear

echo -e "${MINT}${BOLD}"
cat << 'ASCII'
  ███╗   ███╗██╗███╗   ██╗████████╗      █████╗ ██████╗  ██████╗██╗  ██╗
  ████╗ ████║██║████╗  ██║╚══██╔══╝     ██╔══██╗██╔══██╗██╔════╝██║  ██║
  ██╔████╔██║██║██╔██╗ ██║   ██║        ███████║██████╔╝██║     ███████║
  ██║╚██╔╝██║██║██║╚██╗██║   ██║        ██╔══██║██╔══██╗██║     ██╔══██║
  ██║ ╚═╝ ██║██║██║ ╚████║   ██║        ██║  ██║██║  ██║╚██████╗██║  ██║
  ╚═╝     ╚═╝╚═╝╚═╝  ╚═══╝   ╚═╝        ╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝
                                                            L I N U X
ASCII
echo -e "${NC}"
echo -e "  ${BOLD}Welcome to Mint Arch Linux!${NC}"
echo -e "  Standalone rolling Linux with KDE Plasma + Security Tools"
echo ""
echo -e "  ${CYAN}────────────────────────────────────────────────────${NC}"
echo ""

step() {
    echo -e "  ${MINT}${BOLD}[$1/${TOTAL}]${NC} $2"
    echo ""
}
TOTAL=6

# ── Step 1: Update ─────────────────────────────────────────────────────────
step 1 "System Update"
read -r -p "  Update system now? (recommended) [Y/n]: " upd
if [[ ! "$upd" =~ ^[Nn]$ ]]; then
    sudo mint-update || true
fi

# ── Step 2: AUR Helper ────────────────────────────────────────────────────
step 2 "AUR Helper (paru)"
if ! command -v paru &>/dev/null; then
    read -r -p "  Install paru AUR helper? [Y/n]: " aur
    [[ ! "$aur" =~ ^[Nn]$ ]] && mint-setup-aur || true
else
    echo -e "  ${GREEN}✓${NC} paru already installed"
fi

# ── Step 3: Security ─────────────────────────────────────────────────────
step 3 "Privacy & Security"
read -r -p "  Enable firewall, AppArmor, DNS-over-HTTPS? [Y/n]: " sec
[[ ! "$sec" =~ ^[Nn]$ ]] && sudo mint-privacy || true

# ── Step 4: Drivers ───────────────────────────────────────────────────────
step 4 "Hardware Drivers"
read -r -p "  Auto-detect and install GPU/CPU drivers? [Y/n]: " drv
[[ ! "$drv" =~ ^[Nn]$ ]] && sudo mint-driver-manager || true

# ── Step 5: Security Tools ────────────────────────────────────────────────
step 5 "Security Tools"
read -r -p "  Open security tools installer? [y/N]: " tools
[[ "$tools" =~ ^[Yy]$ ]] && sudo mint-tools-setup || true

# ── Step 6: Gaming ───────────────────────────────────────────────────────
step 6 "Gaming Support"
read -r -p "  Install gaming support (Steam, Wine, Proton)? [y/N]: " game
[[ "$game" =~ ^[Yy]$ ]] && sudo mint-gaming || true

# ── Done ──────────────────────────────────────────────────────────────────
mkdir -p "$HOME/.config"
touch "$DONE_FILE"

echo ""
echo -e "  ${MINT}${BOLD}════════════════════════════════════════${NC}"
echo -e "  ${MINT}${BOLD}  Mint Arch Linux setup complete!${NC}"
echo -e "  ${MINT}${BOLD}════════════════════════════════════════${NC}"
echo ""
echo "  Quick reference:"
echo -e "  ${MINT}mint-fetch${NC}       — system info"
echo -e "  ${MINT}mint-health${NC}      — health dashboard"
echo -e "  ${MINT}sudo mint-update${NC} — safe system update"
echo -e "  ${MINT}sudo mint-clean${NC}  — clean disk space"
echo -e "  ${MINT}sudo mint-doctor${NC} — diagnose issues"
echo ""
