#!/usr/bin/env bash
# =============================================================================
# Mint OS - Guided System Installer
# Standalone — uses only official Arch Linux repositories
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

LOGFILE="/tmp/mint-install.log"
exec > >(tee -a "$LOGFILE") 2>&1

# ─── Helpers ─────────────────────────────────────────────────────────────────

banner() {
    clear
    echo -e "${CYAN}"
    echo "  ╔══════════════════════════════════════════╗"
    echo "  ║                                          ║"
    echo "  ║         Mint OS Installer v2.0           ║"
    echo "  ║    Standalone Arch-based Linux Distro    ║"
    echo "  ║                                          ║"
    echo "  ╚══════════════════════════════════════════╝"
    echo -e "${NC}"
}

info()    { echo -e "${GREEN}[+]${NC} $*"; }
warn()    { echo -e "${YELLOW}[!]${NC} $*"; }
error()   { echo -e "${RED}[✗]${NC} $*"; exit 1; }
section() { echo -e "\n${BOLD}${BLUE}── $* ──${NC}\n"; }
confirm() {
    read -r -p "$(echo -e "${YELLOW}[?]${NC} $1 [y/N]: ")" reply
    [[ "$reply" =~ ^[Yy]$ ]]
}

check_root() {
    [[ "$EUID" -eq 0 ]] || error "Run as root: sudo mint-installer"
}

# ─── Disk Selection ──────────────────────────────────────────────────────────

select_disk() {
    section "Disk Selection"
    info "Available disks:"
    echo ""
    lsblk -d -o NAME,SIZE,TYPE,MODEL | grep -v loop
    echo ""
    read -r -p "Enter disk name (e.g. sda, nvme0n1): " DISK
    DISK="/dev/$DISK"
    [ -b "$DISK" ] || error "Disk $DISK not found."
    info "Selected: $DISK"
    warn "ALL DATA ON $DISK WILL BE ERASED!"
    confirm "Continue?" || error "Aborted."
}

# ─── Filesystem Choice ────────────────────────────────────────────────────────

choose_filesystem() {
    section "Filesystem"
    echo "  1) Btrfs  — Recommended (snapshots + rollback support)"
    echo "  2) ext4   — Traditional, stable, widely supported"
    echo ""
    read -r -p "Choice [1]: " FS_CHOICE
    FS_CHOICE="${FS_CHOICE:-1}"
    case "$FS_CHOICE" in
        1) FS_TYPE="btrfs" ;;
        2) FS_TYPE="ext4" ;;
        *) FS_TYPE="btrfs" ;;
    esac
    info "Filesystem: $FS_TYPE"
}

# ─── Partition ────────────────────────────────────────────────────────────────

partition_disk() {
    section "Partitioning ($FS_TYPE)"

    info "Wiping $DISK..."
    wipefs -af "$DISK"
    sgdisk -Z "$DISK"

    info "Creating GPT table..."
    parted -s "$DISK" mklabel gpt
    parted -s "$DISK" mkpart ESP fat32 1MiB 513MiB
    parted -s "$DISK" set 1 esp on
    parted -s "$DISK" mkpart swap linux-swap 513MiB 4609MiB
    parted -s "$DISK" mkpart root "$FS_TYPE" 4609MiB 100%

    if [[ "$DISK" == *"nvme"* ]]; then
        EFI="${DISK}p1"; SWAP="${DISK}p2"; ROOT="${DISK}p3"
    else
        EFI="${DISK}1"; SWAP="${DISK}2"; ROOT="${DISK}3"
    fi

    info "Formatting..."
    mkfs.fat -F32 -n EFI "$EFI"
    mkswap -L swap "$SWAP"

    if [[ "$FS_TYPE" == "btrfs" ]]; then
        mkfs.btrfs -L MintOS "$ROOT"
        mount "$ROOT" /mnt
        # Create Btrfs subvolumes for snapshot support
        btrfs subvolume create /mnt/@
        btrfs subvolume create /mnt/@home
        btrfs subvolume create /mnt/@snapshots
        btrfs subvolume create /mnt/@log
        btrfs subvolume create /mnt/@cache
        umount /mnt
        mount -o noatime,compress=zstd,subvol=@ "$ROOT" /mnt
        mkdir -p /mnt/{home,.snapshots,var/log,var/cache,boot/efi}
        mount -o noatime,compress=zstd,subvol=@home      "$ROOT" /mnt/home
        mount -o noatime,compress=zstd,subvol=@snapshots "$ROOT" /mnt/.snapshots
        mount -o noatime,compress=zstd,subvol=@log       "$ROOT" /mnt/var/log
        mount -o noatime,compress=zstd,subvol=@cache     "$ROOT" /mnt/var/cache
    else
        mkfs.ext4 -L MintOS "$ROOT"
        mount "$ROOT" /mnt
        mkdir -p /mnt/boot/efi
    fi

    mount "$EFI" /mnt/boot/efi
    swapon "$SWAP"
    info "Partitioning done."
}

# ─── User Config ─────────────────────────────────────────────────────────────

get_user_config() {
    section "User Configuration"

    read -r -p "Hostname [mintos]: " HOSTNAME
    HOSTNAME="${HOSTNAME:-mintos}"

    read -r -p "Username: " USERNAME
    while [[ -z "$USERNAME" ]]; do
        error "Username cannot be empty."
        read -r -p "Username: " USERNAME
    done

    read -r -s -p "Password: " PASSWORD; echo ""
    read -r -s -p "Confirm password: " PASSWORD2; echo ""
    while [[ "$PASSWORD" != "$PASSWORD2" ]]; do
        warn "Passwords don't match."
        read -r -s -p "Password: " PASSWORD; echo ""
        read -r -s -p "Confirm: "  PASSWORD2; echo ""
    done

    DETECTED_TZ=$(curl -s --max-time 5 https://ipapi.co/timezone 2>/dev/null || echo "UTC")
    read -r -p "Timezone [$DETECTED_TZ]: " TIMEZONE
    TIMEZONE="${TIMEZONE:-$DETECTED_TZ}"

    section "Desktop Session"
    echo "  1) KDE Plasma (Wayland)  — Recommended"
    echo "  2) KDE Plasma (X11)"
    echo "  3) Both (choose at login)"
    read -r -p "Session [1]: " SESSION_CHOICE
    case "${SESSION_CHOICE:-1}" in
        2) DEFAULT_SESSION="plasmax11" ;;
        *) DEFAULT_SESSION="plasmawayland" ;;
    esac

    section "Gaming Support"
    read -r -p "Install gaming support? (Steam, Wine, Proton) [y/N]: " GAMING
    INSTALL_GAMING=false
    [[ "$GAMING" =~ ^[Yy]$ ]] && INSTALL_GAMING=true
}

# ─── Install ─────────────────────────────────────────────────────────────────

install_base() {
    section "Installing Base System"
    info "This will take a while..."

    local pkgs=(
        base base-devel linux linux-firmware linux-headers
        grub efibootmgr os-prober
        networkmanager sudo
        plasma-meta sddm kde-applications-meta
        zsh zsh-completions zsh-autosuggestions zsh-syntax-highlighting
        pipewire pipewire-pulse wireplumber alsa-utils
        ntfs-3g exfatprogs dosfstools btrfs-progs
        reflector curl wget git
        flatpak xdg-desktop-portal-kde
        snapper snap-pac grub-btrfs
        apparmor ufw fail2ban
        nmap wireshark-qt hashcat john hydra
        fastfetch neofetch htop btop
        lm_sensors smartmontools
        docker docker-compose
        vim neovim nano
    )

    $INSTALL_GAMING && pkgs+=(steam wine wireshark-qt mangohud gamemode)

    pacstrap -K /mnt "${pkgs[@]}"
    info "Base installed."
}

configure_system() {
    section "Configuring System"
    genfstab -U /mnt >> /mnt/etc/fstab

    # Copy Mint OS logo
    mkdir -p /mnt/usr/share/mint-os /mnt/usr/share/pixmaps
    [ -f /usr/share/mint-os/logo.png ] && \
        cp /usr/share/mint-os/logo.png /mnt/usr/share/mint-os/logo.png
    [ -f /usr/share/pixmaps/mintos-logo.png ] && \
        cp /usr/share/pixmaps/mintos-logo.png /mnt/usr/share/pixmaps/mintos-logo.png

    arch-chroot /mnt /bin/bash <<CHROOT
set -e

ln -sf /usr/share/zoneinfo/${TIMEZONE} /etc/localtime
hwclock --systohc

echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=en_US.UTF-8" > /etc/locale.conf

echo "${HOSTNAME}" > /etc/hostname
cat > /etc/hosts <<HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   ${HOSTNAME}.localdomain ${HOSTNAME}
HOSTS

cat > /etc/os-release <<OSREL
NAME="Mint OS"
PRETTY_NAME="Mint OS (Rolling)"
ID=mintos
ID_LIKE=arch
BUILD_ID=rolling
ANSI_COLOR="1;32"
LOGO=mintos-logo
OSREL

echo "root:${PASSWORD}" | chpasswd
useradd -m -G wheel,audio,video,optical,storage,docker,network -s /usr/bin/zsh ${USERNAME}
echo "${USERNAME}:${PASSWORD}" | chpasswd

echo "%wheel ALL=(ALL:ALL) ALL" > /etc/sudoers.d/wheel

systemctl enable NetworkManager sddm bluetooth fstrim.timer
systemctl enable apparmor ufw fail2ban docker 2>/dev/null || true

# Flatpak + Flathub
systemctl enable flatpak-system-helper 2>/dev/null || true
flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo || true

# SDDM
mkdir -p /etc/sddm.conf.d
cat > /etc/sddm.conf.d/default.conf <<SDDM
[General]
HaltCommand=/usr/bin/systemctl poweroff
RebootCommand=/usr/bin/systemctl reboot
Numlock=on
[Theme]
Current=breeze
[Autologin]
Session=${DEFAULT_SESSION}
SDDM

# Snapper (if Btrfs)
if findmnt -n -o FSTYPE / | grep -q btrfs; then
    snapper -c root create-config /
    snapper -c home create-config /home
    systemctl enable snapper-cleanup.timer
    systemctl enable snapper-timeline.timer
fi

# GRUB
grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=MintOS
sed -i 's/GRUB_DISTRIBUTOR=.*/GRUB_DISTRIBUTOR="Mint OS"/' /etc/default/grub
sed -i 's/GRUB_TIMEOUT=.*/GRUB_TIMEOUT=5/' /etc/default/grub
grub-mkconfig -o /boot/grub/grub.cfg

mkinitcpio -P

# ZSH config
cat > /home/${USERNAME}/.zshrc <<ZSH
source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh 2>/dev/null || true
source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh 2>/dev/null || true
PROMPT='%F{green}%n%f@%F{cyan}mintos%f %F{yellow}%~%f %# '
HISTFILE=~/.zsh_history; HISTSIZE=10000; SAVEHIST=10000
setopt appendhistory autocd
autoload -Uz compinit && compinit
alias ls='ls --color=auto'
alias ll='ls -lah'
alias update='sudo mint-update'
alias tools='sudo mint-tools-setup'
alias health='sudo mint-health'
alias snapshot='sudo mint-snapshot'
alias privacy='sudo mint-privacy'
alias hardware='sudo mint-hardware'
ZSH
chown ${USERNAME}:${USERNAME} /home/${USERNAME}/.zshrc

echo "[DONE]"
CHROOT
}

finish() {
    section "Installation Complete"
    info "Mint OS installed successfully!"
    echo ""
    echo -e "  ${BOLD}Next steps:${NC}"
    echo "  1. Remove the installation media"
    echo "  2. Reboot: sudo reboot"
    echo "  3. Log in as: $USERNAME"
    echo "  4. Run 'sudo mint-tools-setup' to install security tools"
    echo "  5. Run 'mint-setup-aur' to enable AUR packages"
    echo ""
    confirm "Reboot now?" && reboot
}

main() {
    banner
    check_root
    section "Welcome to Mint OS Installer"
    echo "  Standalone rolling Linux distro with security tools + KDE Plasma."
    echo ""
    confirm "Begin installation?" || exit 0

    select_disk
    choose_filesystem
    partition_disk
    get_user_config
    install_base
    configure_system
    finish
}

main "$@"
