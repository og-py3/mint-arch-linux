#!/usr/bin/env bash
# =============================================================================
# Mint OS — mint-driver-manager  |  Auto-detect & install hardware drivers
# =============================================================================
set -euo pipefail

LOG_DIR="/var/log/mint-os"; mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/mint-drivers-$(date +%Y%m%d-%H%M%S).log"
exec > >(tee -a "$LOG") 2>&1

MINT='\033[38;2;46;203;113m'; BOLD='\033[1m'; NC='\033[0m'
YELLOW='\033[1;33m'; RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'

info()    { echo -e "${MINT}[+]${NC} $*"; }
ok()      { echo -e "${GREEN}[✓]${NC} $*"; }
warn()    { echo -e "${YELLOW}[!]${NC} $*"; }
section() { echo -e "\n${BOLD}${CYAN}── $* ──${NC}"; }

banner() {
    echo -e "${MINT}${BOLD}"
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║   Mint OS Driver Manager          ║"
    echo "  ╚═══════════════════════════════════╝${NC}"
    echo "  Scanning hardware..."
    echo ""
}

detect_and_install_gpu() {
    section "GPU Drivers"
    local gpu
    gpu=$(lspci | grep -i 'vga\|3d\|display' | head -3)
    echo "$gpu" | while read -r line; do
        echo "    $line"
    done
    echo ""

    if echo "$gpu" | grep -qi "nvidia"; then
        echo -e "  ${BOLD}NVIDIA GPU detected${NC}"
        echo "  1) nvidia-open  (recommended for RTX 16xx+, open source kernel module)"
        echo "  2) nvidia       (proprietary, all cards, best compatibility)"
        echo "  3) nouveau      (open source, basic)"
        echo "  S) Skip"
        read -r -p "  Install driver: " choice
        case "$choice" in
            1) pacman -S --needed --noconfirm nvidia-open-dkms nvidia-utils lib32-nvidia-utils nvidia-settings
               ok "NVIDIA open driver installed" ;;
            2) pacman -S --needed --noconfirm nvidia nvidia-utils lib32-nvidia-utils nvidia-settings
               ok "NVIDIA proprietary driver installed" ;;
            3) pacman -S --needed --noconfirm xf86-video-nouveau mesa
               ok "Nouveau driver installed" ;;
            [Ss]) info "Skipped GPU driver" ;;
        esac

    elif echo "$gpu" | grep -qi "amd\|radeon"; then
        info "AMD GPU detected — installing AMDGPU + Vulkan..."
        pacman -S --needed --noconfirm \
            xf86-video-amdgpu mesa lib32-mesa \
            vulkan-radeon lib32-vulkan-radeon \
            libva-mesa-driver mesa-vdpau
        ok "AMD drivers installed"

    elif echo "$gpu" | grep -qi "intel"; then
        info "Intel GPU detected — installing Intel drivers..."
        pacman -S --needed --noconfirm \
            mesa lib32-mesa \
            vulkan-intel lib32-vulkan-intel \
            intel-media-driver
        ok "Intel drivers installed"

    elif echo "$gpu" | grep -qi "vmware\|svga"; then
        info "VMware detected..."
        pacman -S --needed --noconfirm xf86-video-vmware open-vm-tools
        systemctl enable vmtoolsd vmware-vmblock-fuse 2>/dev/null || true
        ok "VMware guest tools installed"

    elif echo "$gpu" | grep -qi "virtualbox\|vbox"; then
        info "VirtualBox detected..."
        pacman -S --needed --noconfirm virtualbox-guest-utils
        systemctl enable vboxservice 2>/dev/null || true
        ok "VirtualBox guest additions installed"

    elif echo "$gpu" | grep -qi "qxl\|virtio"; then
        info "QEMU/KVM detected..."
        pacman -S --needed --noconfirm xf86-video-qxl spice-vdagent qemu-guest-agent
        systemctl enable spice-vdagentd qemu-guest-agent 2>/dev/null || true
        ok "QEMU guest tools installed"

    else
        warn "GPU not specifically detected — installing generic Mesa"
        pacman -S --needed --noconfirm mesa lib32-mesa xf86-video-fbdev
    fi
}

detect_cpu_microcode() {
    section "CPU Microcode"
    if grep -q "Intel" /proc/cpuinfo; then
        pacman -S --needed --noconfirm intel-ucode
        ok "Intel microcode updated"
    elif grep -q "AMD" /proc/cpuinfo; then
        pacman -S --needed --noconfirm amd-ucode
        ok "AMD microcode updated"
    fi
}

detect_wifi() {
    section "WiFi Drivers"
    local wifi_dev
    wifi_dev=$(lspci | grep -i 'wireless\|wifi\|wi-fi' || lsusb | grep -i 'wireless' || echo "")
    if [[ -n "$wifi_dev" ]]; then
        echo "    $wifi_dev"
        if echo "$wifi_dev" | grep -qi "broadcom\|bcm"; then
            warn "Broadcom WiFi detected — may need broadcom-wl"
            read -r -p "  Install broadcom-wl? [y/N]: " c
            [[ "$c" =~ ^[Yy]$ ]] && pacman -S --needed --noconfirm broadcom-wl-dkms
        elif echo "$wifi_dev" | grep -qi "realtek"; then
            info "Realtek WiFi — installing firmware..."
            pacman -S --needed --noconfirm linux-firmware
            ok "Realtek firmware installed"
        else
            ok "WiFi driver likely included in linux-firmware"
        fi
    else
        info "No dedicated WiFi adapter detected"
    fi
}

detect_bluetooth() {
    section "Bluetooth"
    if lsusb 2>/dev/null | grep -qi "bluetooth" || lspci | grep -qi "bluetooth"; then
        pacman -S --needed --noconfirm bluez bluez-utils
        systemctl enable bluetooth
        ok "Bluetooth enabled"
    else
        info "No Bluetooth adapter detected"
    fi
}

detect_printer() {
    section "Printing"
    pacman -S --needed --noconfirm cups cups-pdf
    systemctl enable cups
    if lsusb 2>/dev/null | grep -qi "hewlett\|hp "; then
        pacman -S --needed --noconfirm hplip
        ok "HP printer support installed"
    fi
    ok "CUPS printing enabled"
}

rebuild_initramfs() {
    section "Rebuilding Initramfs"
    mkinitcpio -P
    if command -v grub-mkconfig &>/dev/null; then
        grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null || true
    fi
    ok "Initramfs rebuilt"
}

main() {
    banner
    [[ "$EUID" -eq 0 ]] || { echo "Run as root: sudo mint-driver-manager"; exit 1; }
    detect_and_install_gpu
    detect_cpu_microcode
    detect_wifi
    detect_bluetooth
    detect_printer
    rebuild_initramfs

    echo ""
    ok "Driver setup complete. Reboot recommended."
    read -r -p "Reboot now? [y/N]: " r
    [[ "$r" =~ ^[Yy]$ ]] && reboot
}

main "$@"
