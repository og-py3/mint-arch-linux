#!/usr/bin/env bash
# Mint OS — zram compressed swap initializer
# Uses lz4 compression for best speed/ratio balance

set -euo pipefail

ZRAM_DEV="/dev/zram0"
RAM_KB=$(grep MemTotal /proc/meminfo | awk '{print $2}')
RAM_MB=$((RAM_KB / 1024))

# Use 50% of RAM for zram (capped at 8GB)
ZRAM_SIZE_MB=$(( RAM_MB / 2 ))
(( ZRAM_SIZE_MB > 8192 )) && ZRAM_SIZE_MB=8192

modprobe zram num_devices=1

echo lz4 > /sys/block/zram0/comp_algorithm
echo "${ZRAM_SIZE_MB}M" > /sys/block/zram0/disksize

mkswap -L zram0 "$ZRAM_DEV"
swapon -p 100 "$ZRAM_DEV"
