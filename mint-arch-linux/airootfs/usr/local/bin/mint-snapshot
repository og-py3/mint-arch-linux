#!/usr/bin/env bash
# =============================================================================
# Mint OS - Snapshot & Rollback Manager (Snapper + Btrfs)
# Easy system snapshot and rollback interface
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${GREEN}[+]${NC} $*"; }
warn()    { echo -e "${YELLOW}[!]${NC} $*"; }
error()   { echo -e "${RED}[✗]${NC} $*"; exit 1; }
section() { echo -e "\n${BOLD}${CYAN}── $* ──${NC}\n"; }

check_root() {
    [[ "$EUID" -eq 0 ]] || error "Run as root: sudo mint-snapshot"
}

check_btrfs() {
    if ! findmnt -n -o FSTYPE / | grep -q btrfs; then
        error "Root filesystem is not Btrfs. Snapshots require Btrfs."
    fi
    if ! command -v snapper &>/dev/null; then
        warn "Snapper not installed. Installing..."
        pacman -S --needed --noconfirm snapper snap-pac grub-btrfs
        snapper -c root create-config /
        info "Snapper configured."
    fi
}

banner() {
    echo -e "${CYAN}${BOLD}"
    echo "  Mint OS Snapshot & Rollback Manager"
    echo -e "${NC}"
}

list_snapshots() {
    section "Available Snapshots"
    snapper -c root list
}

create_snapshot() {
    section "Creating Snapshot"
    read -r -p "Description [manual snapshot]: " desc
    desc="${desc:-manual snapshot}"
    snapper -c root create --description "$desc" --cleanup-algorithm number
    info "Snapshot created: $desc"
}

delete_snapshot() {
    section "Delete Snapshot"
    list_snapshots
    echo ""
    read -r -p "Enter snapshot number to delete: " num
    snapper -c root delete "$num"
    info "Snapshot $num deleted."
}

rollback_snapshot() {
    section "Rollback to Snapshot"
    warn "This will revert your system to a previous state."
    warn "Current state will be saved as a new snapshot first."
    echo ""
    list_snapshots
    echo ""
    read -r -p "Enter snapshot number to rollback to: " num
    echo ""
    read -r -p "Are you sure? This requires a reboot. [y/N]: " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { info "Cancelled."; exit 0; }

    snapper -c root undochange "${num}..0"
    grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null || true

    info "Rollback complete. Please reboot."
    read -r -p "Reboot now? [y/N]: " reboot_now
    [[ "$reboot_now" =~ ^[Yy]$ ]] && reboot
}

compare_snapshots() {
    section "Compare Snapshots"
    list_snapshots
    echo ""
    read -r -p "From snapshot: " from
    read -r -p "To snapshot (0 = current): " to
    snapper -c root diff "$from..$to"
}

show_menu() {
    echo -e "${BOLD}Mint OS Snapshot Manager${NC}"
    echo ""
    echo "  1) List all snapshots"
    echo "  2) Create new snapshot"
    echo "  3) Delete a snapshot"
    echo "  4) Rollback to a snapshot"
    echo "  5) Compare two snapshots"
    echo "  Q) Quit"
    echo ""
}

main() {
    banner
    check_root
    check_btrfs

    while true; do
        show_menu
        read -r -p "Choice: " choice
        echo ""
        case "$choice" in
            1) list_snapshots ;;
            2) create_snapshot ;;
            3) delete_snapshot ;;
            4) rollback_snapshot ;;
            5) compare_snapshots ;;
            [Qq]) echo "Goodbye!"; exit 0 ;;
            *) warn "Invalid choice." ;;
        esac
        echo ""
    done
}

main "$@"
