{
  "name": "Mint Arch Linux VM Desktop",
  "build": {
    "dockerfile": "mint-arch-desktop/Dockerfile",
    "context": "."
  },
  "workspaceFolder": "/workspaces/mint-arch-linux",
  "forwardPorts": [
    3000,
    5900
  ],
  "portsAttributes": {
    "3000": {
      "label": "Mint Arch Linux Desktop (noVNC)",
      "onAutoForward": "openBrowser"
    },
    "5900": {
      "label": "VNC (raw)",
      "onAutoForward": "ignore"
    }
  },
  "postStartCommand": "bash /workspaces/mint-arch-linux/mint-arch-desktop/scripts/init-desktop.sh",
  "remoteUser": "root",
  "containerEnv": {
    "ISO_PATH": "/vm/mintarch.iso",
    "VM_RAM": "2048",
    "VM_CPUS": "2",
    "DISK_SIZE": "20G"
  },
  "runArgs": [
    "--privileged",
    "--device=/dev/kvm"
  ]
}